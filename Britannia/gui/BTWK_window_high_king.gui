types HighKingWindowTypes
{
	type HighKingStanceSupportValueText = textbox {
		block "textbox_overrides" { }
		using = DefaultTooltipText
		using = tooltip_se
		block "text_format" {
			default_format = "#V"
		}

		fonttintcolor = "[TooltipInfo.GetTintColor]"
		alwaystransparent = no
		
		tooltipwidget = {
		}
	}
}